<VirtualHost *:{{mediawiki_httpd_port}}>
    ServerName {{ mediawiki_server_name }}
    DocumentRoot {{ mediawiki_document_root }}/mediawiki
    <Directory {{ mediawiki_document_root }}>
        Options FollowSymLinks
        AllowOverride All
        Require all granted
    </Directory>
    ErrorLog {{ mediawiki_error_log }}
    CustomLog {{ mediawiki_custom_log }} {{ mediawiki_custom_log_type }}
</VirtualHost>
Listen {{mediawiki_httpd_port}}